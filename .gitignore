# Dependencies
node_modules/
**/node_modules/

# Environment variables (sensitive data)
.env
**/.env
*.env.local
*.env.development.local
*.env.test.local
*.env.production.local

# WhatsApp Web.js auth & cache (contains session data)
backend/.wwebjs_auth/
backend/.wwebjs_cache/

# Uploads (user-generated files)
backend/uploads/

