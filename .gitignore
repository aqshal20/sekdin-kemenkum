logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Lock files (optional, keep package-lock.json for reproducible builds)
# package-lock.json

# Temporary files
*.tmp
*.temp
backend/server.js.tmp

# OS files
.DS_Store
Thumbs.db

# Editor directories
.vscode/
.idea/
*.swp
*.swo

# Build output
dist/
build/

# Test files (opsional - hapus jika ingin menyertakan)
